    %% Page to Layout connections
    PageGeneral --> DiagramLayout
    PageSequence --> DiagramLayout
    PageState --> DiagramLayout
    PageJourney --> DiagramLayout
    PageClass --> DiagramLayout

    %% Layout to Components connections
    DiagramLayout --> Navigation
    DiagramLayout --> DiagramHeader
    DiagramLayout --> ErrorBanner
    DiagramLayout --> DiagramEditor
    DiagramLayout --> DiagramPreview
    DiagramLayout --> ExamplesCarousel
    DiagramLayout --> SavedDiagramsList

    %% Components to Stores connections
    DiagramEditor -.uses.-> DiagramStore
    DiagramPreview -.uses.-> DiagramStore
    DiagramHeader -.uses.-> DiagramStore
    ExamplesCarousel -.uses.-> DiagramStore
    SavedDiagramsList -.uses.-> SavedDiagramsStore
    DiagramHeader -.uses.-> SavedDiagramsStore

    %% Components to Utils connections
    DiagramPreview -.uses.-> MermaidRenderer
    DiagramHeader -.uses.-> MermaidRenderer

    %% Utils to External connections
    MermaidRenderer --> Mermaid
    SavedDiagramsStore --> LocalStorage

    %% Styling
    classDef pageStyle fill:#fff4e6,stroke:#ffa500,stroke-width:2px
    classDef layoutStyle fill:#e6f3ff,stroke:#0066cc,stroke-width:3px
    classDef componentStyle fill:#e6ffe6,stroke:#00aa00,stroke-width:2px
    classDef storeStyle fill:#ffe6f0,stroke:#cc0066,stroke-width:2px
    classDef utilStyle fill:#f0e6ff,stroke:#6600cc,stroke-width:2px
    classDef externalStyle fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class PageGeneral,PageSequence,PageState,PageJourney,PageClass pageStyle
    class DiagramLayout layoutStyle
    class Navigation,DiagramHeader,ErrorBanner,DiagramEditor,DiagramPreview,ExamplesCarousel,SavedDiagramsList componentStyle
