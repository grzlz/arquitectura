        SavedDiagramsList["SavedDiagramsList.svelte<br/>Grid of saved diagrams<br/>Load/Delete actions"]
    end

    subgraph "State Management (src/lib/stores/)"
        DiagramStore["diagramStore.js<br/>State: diagramCode, error,<br/>currentName, currentExampleIndex"]

        SavedDiagramsStore["savedDiagramsStore.js<br/>localStorage operations<br/>load, save, delete"]
    end

    subgraph "Utilities (src/lib/utils/)"
        MermaidRenderer["mermaidRenderer.js<br/>initializeMermaid()<br/>renderDiagram()<br/>exportSVG()<br/>copyToClipboard()"]
    end

    subgraph "External Dependencies"
        Mermaid["mermaid library<br/>Diagram rendering"]
        LocalStorage["Browser localStorage<br/>Persistence"]
