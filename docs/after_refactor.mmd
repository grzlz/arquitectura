graph TB
    subgraph "Page Layer (50 lines each)"
        PageGeneral["+page.svelte<br/>(General)"]
        PageSequence["sequence/+page.svelte"]
        PageState["state/+page.svelte"]
        PageJourney["journey/+page.svelte"]
        PageClass["class/+page.svelte"]
    end

    subgraph "Layout Component"
        DiagramLayout["DiagramLayout.svelte<br/>Master Composition<br/>Props: title, description, examples, storageKey"]
    end

    subgraph "UI Components (src/lib/components/)"
        Navigation["Navigation.svelte<br/>5 diagram type links<br/>Highlights active page"]

        DiagramHeader["DiagramHeader.svelte<br/>Title, description, actions<br/>Save, Export, Copy, Refresh"]

        ErrorBanner["ErrorBanner.svelte<br/>Error display<br/>Animated, dismissible"]

